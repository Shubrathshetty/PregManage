# PregManage Backend Environment Variables
# Copy this file to .env and fill in the values

# MongoDB Atlas connection string (REQUIRED)
MONGODB_URI=mongodb+srv://your_user:your_password@cluster0.xxxxx.mongodb.net/pregmanage?retryWrites=true&w=majority

# JWT Configuration (REQUIRED)
JWT_SECRET=your_secure_jwt_secret_key_at_least_20_chars
JWT_EXPIRES_IN=7d

# Server Port (optional, default: 3000)
PORT=3000

# Environment (optional, default: development)
NODE_ENV=development

# Default admin password (optional, used to create/reset admin on startup)
# Remove this in production after initial setup
DEFAULT_ADMIN_PASSWORD=your_admin_password_here
